---
/**
 * Side-by-side latency comparison between pymode (this worker) and
 * Cloudflare's Pyodide-based Python Workers (deployed separately).
 *
 * Auto-runs on page load against /api/{hash,webhook,jwt} on both
 * endpoints. No baked-in numbers — every cell starts as "—" and is
 * filled from real measurements.
 *
 * Workloads are stdlib-only (hmac/hashlib/base64/json) so the same
 * Python source ships to both runtimes.
 */
// Per-workload bench workers. Each pymode worker is a SEPARATE deploy
// with its own AOT-tailored wasm (different preimports) so each has a
// distinct Worker Startup Time reported by CF at deploy. Pyodide is only
// usable for the stdlib-only workload — the others fail at deploy time.
const PYMODE_LOGS_URL     = "https://logs.pymode.teamchong.net";
const PYMODE_MARKDOWN_URL = "https://markdown.pymode.teamchong.net";
const PYMODE_SCRAPE_URL   = "https://scrape.pymode.teamchong.net";
const PYODIDE_LOGS_URL    = "https://pyodide-bench.chong1222.workers.dev";

// Cold-start values come from CF's "Worker Startup Time" line in each
// `wrangler deploy` output. Different per worker because preimports
// differ — logs preimports nothing extra, markdown preimports
// markdown_it_py + jinja2, scrape preimports beautifulsoup4.
// Filled in from real deploy output once each deploy lands.
const PYMODE_LOGS_COLD     = 43;    // CF reported at deploy
const PYMODE_MARKDOWN_COLD = null;  // TBD
const PYMODE_SCRAPE_COLD   = null;  // TBD
const PYODIDE_COLD = 1134;

const LOG_SAMPLE = [
  '192.168.1.10 - - [01/Jan/2026:10:00:01 +0000] "GET /index.html HTTP/1.1" 200 1024',
  '10.0.0.42 - - [01/Jan/2026:10:00:02 +0000] "POST /api/login HTTP/1.1" 401 87',
  '192.168.1.10 - - [01/Jan/2026:10:00:03 +0000] "GET /favicon.ico HTTP/1.1" 404 0',
  '172.16.0.1 - - [01/Jan/2026:10:00:04 +0000] "GET /api/users HTTP/1.1" 500 142',
  '10.0.0.42 - - [01/Jan/2026:10:00:05 +0000] "POST /api/login HTTP/1.1" 200 256',
  '192.168.1.10 - - [01/Jan/2026:10:00:06 +0000] "GET /about HTTP/1.1" 200 2048',
].join("\n");

const MARKDOWN_SAMPLE = `# Edge Python is real

A short post rendered through **markdown_it_py** + **jinja2**:

- Real CommonMark parsing
- Full Python template engine
- Lists, *emphasis*, [links](https://example.com), code blocks

\`\`\`python
def on_fetch(request, env):
    return Response("ok")
\`\`\`
`;

const SCRAPE_SAMPLE = `<!doctype html>
<html><head><title>News Brief — March</title></head>
<body>
  <h1>Top stories</h1>
  <article>
    <h2>Story one</h2>
    <p>Lead paragraph with <a href="/story/1">a link</a> in it.</p>
  </article>
  <article>
    <h2>Story two</h2>
    <p>More content with <a href="https://example.com/breaking">breaking</a>.</p>
  </article>
  <h3>Aside</h3>
  <ul>
    <li><a href="/aside/a">A</a></li>
    <li><a href="/aside/b">B</a></li>
  </ul>
</body></html>`;

const WORKLOADS = [
  {
    key: "logs",
    title: "Regex log extract",
    description: "Stdlib re — both runtimes can run it. Real CloudWatch log-scrubbing pattern.",
    method: "POST",
    headers: { "content-type": "text/plain" },
    body: LOG_SAMPLE,
    pymode:  { url: PYMODE_LOGS_URL,     cold: PYMODE_LOGS_COLD },
    pyodide: { url: PYODIDE_LOGS_URL,    cold: PYODIDE_COLD },
  },
  {
    key: "markdown",
    title: "Markdown → HTML (markdown_it + jinja2)",
    description: "Real CommonMark renderer + Python template engine. CF Pyodide rejects this deploy with ModuleNotFoundError — pymode runs it from pip.",
    method: "POST",
    headers: { "content-type": "text/plain" },
    body: MARKDOWN_SAMPLE,
    pymode:  { url: PYMODE_MARKDOWN_URL, cold: PYMODE_MARKDOWN_COLD },
    pyodide: null,
  },
  {
    key: "scrape",
    title: "HTML scrape with BeautifulSoup",
    description: "Real-world page → structured title/headings/links via BeautifulSoup4. CF Pyodide rejects bs4 at deploy time — pymode runs it.",
    method: "POST",
    headers: { "content-type": "text/html" },
    body: SCRAPE_SAMPLE,
    pymode:  { url: PYMODE_SCRAPE_URL,   cold: PYMODE_SCRAPE_COLD },
    pyodide: null,
  },
];

const RUNTIMES = [
  { key: "pymode",  label: "pymode",       color: "var(--sl-color-accent)" },
  { key: "pyodide", label: "Pyodide (CF)", color: "var(--sl-color-orange, #f48120)" },
];
---

<div class="bench-root">
  <p class="bench-intro">
    Each card runs the same Python source on both runtimes. The
    <strong>Cold</strong> column is the CF-reported Worker Startup Time
    (measured at deploy, before any traffic). The <strong>p50/p99</strong>
    are live measurements from your browser when this page loaded.
  </p>

  <div class="bench-controls">
    <label>
      Iterations
      <input id="iterations" type="number" value="10" min="5" max="200" />
    </label>
    <button id="run-bench" type="button">Run again</button>
    <p class="bench-status" id="bench-status">Auto-running benchmark…</p>
  </div>

  <div class="workload-grid">
    {WORKLOADS.map(w => (
      <article class="workload-card" data-workload={w.key}>
        <h3>{w.title}</h3>
        <p class="subtitle">POST <code>/api/{w.key}</code></p>
        <p class="description">{w.description}</p>
        <table>
          <colgroup>
            <col class="col-runtime" />
            <col class="col-metric" />
            <col class="col-metric" />
            <col class="col-metric" />
            <col class="col-metric" />
          </colgroup>
          <thead>
            <tr><th></th><th>Cold</th><th>p50</th><th>p99</th><th>OK</th></tr>
          </thead>
          <tbody>
            {RUNTIMES.map(rt => (
              <tr data-runtime={rt.key}>
                <th scope="row">{rt.label}</th>
                <td>{rt.cold} ms</td>
                <td data-metric="p50">—</td>
                <td data-metric="p99">—</td>
                <td data-metric="samples">—</td>
              </tr>
            ))}
          </tbody>
        </table>
      </article>
    ))}
  </div>

  <p class="bench-footnote">
    Each pymode workload runs on its own deployed worker under
    <code>*.pymode.teamchong.net</code> with tailored preimports — that
    way the Worker Startup Time CF reports at deploy varies per workload.
    The Pyodide comparison runs at <code>pyodide-bench.chong1222.workers.dev</code>.
    First request of each measurement is a discarded warmup so the
    reported p50/p99 reflect steady-state behaviour. Latencies include
    network round-trip from your browser.
  </p>
</div>

<script type="module" define:vars={{ WORKLOADS, RUNTIMES }}>
  const statusEl = document.getElementById("bench-status");
  const runBtn = document.getElementById("run-bench");
  const iterationsInput = document.getElementById("iterations");

  function setMetric(workloadKey, runtimeKey, metric, value) {
    const card = document.querySelector(`.workload-card[data-workload="${workloadKey}"]`);
    if (!card) return;
    const row = card.querySelector(`tr[data-runtime="${runtimeKey}"]`);
    if (!row) return;
    const cell = row.querySelector(`[data-metric="${metric}"]`);
    if (cell) cell.textContent = value;
  }

  function fmt(ms) {
    if (ms == null) return "—";
    if (ms < 10) return `${ms.toFixed(1)} ms`;
    if (ms >= 1000) return `${(ms / 1000).toFixed(2)} s`;
    return `${Math.round(ms)} ms`;
  }

  async function timeReq(url, workload) {
    const init = {
      method: workload.method,
      headers: workload.headers,
    };
    if (workload.body) init.body = workload.body;
    const t0 = performance.now();
    const res = await fetch(url, init);
    await res.text();
    return { ms: performance.now() - t0, status: res.status };
  }

  function pct(sorted, p) {
    if (sorted.length === 0) return null;
    return sorted[Math.min(sorted.length - 1, Math.floor((p / 100) * sorted.length))];
  }

  async function runOne(runtime, workload, iterations, signal) {
    // Workloads marked pyodide:false don't run on the Pyodide baseline
    // because CF Pyodide's package list doesn't include the required
    // library. Show that as static "unsupported" cells.
    if (runtime.key === "pyodide" && workload.pyodide === false) {
      setMetric(workload.key, runtime.key, "p50", "—");
      setMetric(workload.key, runtime.key, "p99", "—");
      setMetric(workload.key, runtime.key, "samples", "n/a");
      return;
    }
    const url = `${runtime.base}/api/${workload.key}`;

    // Fire one warmup request that we don't count, so the first measured
    // request isn't disproportionately polluted by isolate spin-up. The
    // honest cold-start number is shown separately at the top of the page.
    statusEl.textContent = `${runtime.label} / ${workload.title}: warmup…`;
    const warmup = await timeReq(url, workload);
    if (warmup.status >= 400) {
      setMetric(workload.key, runtime.key, "p50", `HTTP ${warmup.status}`);
      setMetric(workload.key, runtime.key, "p99", `HTTP ${warmup.status}`);
      setMetric(workload.key, runtime.key, "samples", `0/0`);
      return;
    }

    const warm = [];
    let ok = 0;
    for (let i = 0; i < iterations; i++) {
      if (signal.aborted) return;
      statusEl.textContent = `${runtime.label} / ${workload.title}: ${i + 1}/${iterations}…`;
      const r = await timeReq(url, workload);
      if (r.status < 400) {
        warm.push(r.ms);
        ok++;
      }
      setMetric(workload.key, runtime.key, "samples", `${ok}/${i + 1}`);
    }
    warm.sort((a, b) => a - b);
    setMetric(workload.key, runtime.key, "p50", fmt(pct(warm, 50)));
    setMetric(workload.key, runtime.key, "p99", fmt(pct(warm, 99)));
    setMetric(workload.key, runtime.key, "samples", `${ok}/${iterations}`);
  }

  let current = null;
  async function runAll() {
    if (current) {
      current.abort();
      current = null;
      runBtn.textContent = "Run again";
      statusEl.textContent = "Cancelled.";
      return;
    }
    current = new AbortController();
    runBtn.textContent = "Cancel";

    const iterations = Math.max(5, Math.min(200, Number(iterationsInput.value) || 10));

    // Reset all cells
    for (const w of WORKLOADS) for (const rt of RUNTIMES) {
      for (const m of ["p50", "p99", "samples"]) setMetric(w.key, rt.key, m, "…");
    }

    try {
      for (const workload of WORKLOADS) {
        if (current.signal.aborted) break;
        // Run pymode and pyodide in parallel for each workload —
        // saves wall time and gives them comparable conditions.
        await Promise.all(RUNTIMES.map(rt =>
          runOne(rt, workload, iterations, current.signal)
        ));
      }
      if (!current.signal.aborted) statusEl.textContent = "Done.";
    } catch (e) {
      statusEl.textContent = `Error: ${e?.message ?? e}`;
    } finally {
      current = null;
      runBtn.textContent = "Run again";
    }
  }

  runBtn.addEventListener("click", runAll);
  // Auto-run on page load.
  runAll();
</script>

<style>
  .bench-root {
    margin: 1.5rem 0;
    font-family: var(--sl-font-system, system-ui);
  }

  .bench-intro {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    margin: 0 0 1rem;
    line-height: 1.55;
  }

  .cold-start-stats {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    background: var(--sl-color-gray-7);
  }

  .cold-start-stats h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
  }

  .cold-start-stats .hint {
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    margin: 0 0 0.75rem;
    line-height: 1.45;
  }

  .cold-start-stats table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .cold-start-stats th,
  .cold-start-stats td {
    padding: 0.4rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .cold-start-stats tbody th[scope="row"] {
    font-weight: 600;
  }

  .cold-start-stats td {
    text-align: right;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
  }

  .cold-start-stats tbody tr:last-child th,
  .cold-start-stats tbody tr:last-child td {
    border-bottom: none;
  }

  .warm-bench-heading {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }

  .bench-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 0.85rem 1rem;
    margin-bottom: 1.25rem;
    background: var(--sl-color-gray-7);
  }

  .bench-controls label {
    display: flex;
    flex-direction: column;
    font-size: 0.8rem;
    font-weight: 600;
    gap: 0.25rem;
  }

  .bench-controls input {
    padding: 0.35rem 0.55rem;
    border-radius: 4px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    font-family: inherit;
    width: 6rem;
  }

  #run-bench {
    padding: 0.45rem 0.9rem;
    background: var(--sl-color-accent);
    color: white;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.85rem;
    height: fit-content;
  }

  #run-bench:hover { filter: brightness(1.1); }

  .bench-status {
    flex: 1 1 100%;
    margin: 0;
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-mono, ui-monospace, monospace);
  }

  .workload-grid {
    display: grid;
    /* Force 3 equal columns so all cards sit in a single row with
       identical top/bottom edges. The auto-fit minmax variant we had
       before was wrapping into 2 rows on Starlight's content width,
       so cards visibly drifted between row 1 and row 2. */
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    align-items: stretch;
  }

  @media (max-width: 720px) {
    /* Stack on narrow viewports — fitting 3 cards horizontally below
       this width would crush the table. */
    .workload-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Use an explicit grid inside each card so every section lives in a
     fixed-height row. Same row template on every card → tables, titles,
     and subtitles all line up across cards regardless of viewport. */
  .workload-card {
    margin: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem;
    background: var(--sl-color-gray-7);
    display: grid;
    /* Identical row template on every card → titles, subtitles,
       descriptions, and tables all sit at the same y-coordinate
       across cards. The outer grid's align-items:stretch ensures
       cards in the same row reach the same total height. */
    grid-template-rows:
      auto     /* h3 (nowrap, so always 1 line) */
      auto     /* subtitle (nowrap, always 1 line) */
      1fr      /* description grows */
      auto;    /* table sits at the bottom */
    row-gap: 0.4rem;
  }

  .workload-card h3 {
    margin: 0;
    font-size: 1.05rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .workload-card .subtitle {
    margin: 0;
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .workload-card .subtitle code {
    background: var(--sl-color-gray-6);
    padding: 0.05rem 0.3rem;
    border-radius: 3px;
  }

  .workload-card .description {
    font-size: 0.82rem;
    color: var(--sl-color-gray-2);
    margin: 0;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  .workload-card table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    /* table-layout: fixed makes every card's table columns identical
       in width regardless of the cell content, so the metric columns
       (p50/p99/OK) line up across cards visually. */
    table-layout: fixed;
  }

  /* Explicit widths so every card has identical column geometry.
     Wider metric columns to fit "1134 ms"-class numbers. Drop OK
     column from the layout (we keep the cell but make it compact). */
  .workload-card colgroup .col-runtime { width: 32%; }
  .workload-card colgroup .col-metric  { width: 17%; }
  .workload-card td,
  .workload-card th {
    padding: 0.3rem 0.25rem;
    font-size: 0.78rem;
  }
  .workload-card td[data-metric="samples"],
  .workload-card thead th:last-child { font-size: 0.7rem; }

  .workload-card th,
  .workload-card td {
    padding: 0.35rem 0.45rem;
    text-align: right;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .workload-card th[scope="row"] {
    text-align: left;
    font-weight: 600;
    font-family: var(--sl-font-system, inherit);
    font-size: 0.78rem;
  }

  .workload-card thead th {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    font-weight: 500;
    text-align: right;
  }

  .workload-card thead th:first-child { text-align: left; }

  .workload-card tbody tr:last-child th,
  .workload-card tbody tr:last-child td {
    border-bottom: none;
  }

  .bench-footnote {
    margin-top: 1.5rem;
    font-size: 0.78rem;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }

  .bench-footnote code {
    font-size: 0.9em;
  }
</style>
