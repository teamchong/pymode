{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "pymode-pydantic-test",
  "main": "pydantic-worker.ts",
  "compatibility_date": "2024-01-01",

  "limits": {
    "cpu_ms": 30000
  },

  "rules": [
    {
      "type": "CompiledWasm",
      "globs": ["**/*.wasm"],
      "fallthrough": false
    },
    {
      "type": "Data",
      "globs": ["**/*.zip", "**/*.dat"],
      "fallthrough": false
    }
  ]
}
