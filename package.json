{
  "name": "pymode",
  "version": "0.1.0",
  "description": "Python compiled to WebAssembly using Zig, targeting Cloudflare Workers",
  "private": true,
  "scripts": {
    "build:phase1": "./scripts/build-phase1.sh",
    "build:phase2": "npx tsx scripts/build-phase2.ts",
    "build:wizer": "npx tsx scripts/build-wizer.ts",
    "build:stdlib": "npx tsx scripts/build-stdlib.ts",
    "build:variant": "npx tsx scripts/build-variant.ts",
    "build:recipe": "npx tsx scripts/build-recipe.ts",
    "build:extension": "npx tsx scripts/build-extension.ts",
    "generate:stdlib": "npx tsx scripts/generate-stdlib-fs.ts",
    "bundle:project": "npx tsx scripts/bundle-project.ts",
    "bundle:packages": "npx tsx scripts/bundle-packages.ts",
    "install:packages": "npx tsx scripts/pymode-install.ts",
    "test": "vitest run",
    "test:pydantic": "vitest run --config vitest-pydantic.config.ts",
    "test:all": "vitest run && vitest run --config vitest-pydantic.config.ts",
    "test:watch": "vitest",
    "test:legacy": "npx tsx scripts/test.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p cli/tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.20",
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/node": "^25.4.0",
    "fflate": "^0.8.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "wrangler": "^3.57.0"
  }
}
