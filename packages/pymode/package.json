  "files": [
    "src/",
    "python.wasm",
    "stdlib-data.dat"
  ],
  "keywords": ["cloudflare", "workers", "python", "wasm", "wasi", "cpython"],
  "license": "MIT",
  "peerDependencies": {
    "wrangler": ">=3.0.0"
  }
}
