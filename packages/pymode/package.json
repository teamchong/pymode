{
  "name": "pymode",
  "version": "0.1.0",
  "description": "Run CPython 3.13 on Cloudflare Workers — WASM runtime, WASI, Asyncify",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./wasi": "./src/wasi.ts",
